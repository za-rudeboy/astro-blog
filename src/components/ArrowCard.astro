---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
}

const { entry } = Astro.props;
---

<a href={`/${entry.collection}/${entry.slug}`} class="surface accent-ring relative group flex flex-nowrap gap-4 rounded-card border px-4 py-4 pr-11 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[color:var(--color-accent)] hover:bg-[color:var(--color-surface-strong)] hover:text-[color:var(--color-heading)]">
  <div class="flex flex-col flex-1 truncate">
    <div class="text-sm text-muted">
      <FormattedDate date={entry.data.date} />
    </div>
    <div class="font-semibold text-heading">
      {entry.data.title}
    </div>
    <div class="text-sm text-muted">
      {entry.data.description}
    </div>
  </div>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 24 24"
    class="absolute right-3 top-1/2 size-5 -translate-y-1/2 fill-none stroke-current stroke-2 text-[color:var(--color-accent)]">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-100" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</a>

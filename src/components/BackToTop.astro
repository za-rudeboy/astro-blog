<button id="back-to-top" class="surface relative group flex w-fit flex-nowrap rounded-card border py-1.5 pl-8 pr-3 transition-colors duration-300 ease-in-out hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-heading)]">
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 24 24"
    class="absolute left-2 top-1/2 size-4 -translate-y-1/2 rotate-90 fill-none stroke-current stroke-2 text-[color:var(--color-accent)]">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-2 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
